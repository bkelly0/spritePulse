{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sprite-pulse.dev/schema/sprite-pulse-atlas.schema.json",
  "title": "SpritePulse Atlas Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": ["atlasImageFile", "frames"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "const": 1
    },
    "atlasImageFile": {
      "type": "string",
      "minLength": 1
    },
    "frames": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["x", "y", "width", "height"],
        "properties": {
          "x": {
            "type": "number",
            "minimum": 0
          },
          "y": {
            "type": "number",
            "minimum": 0
          },
          "width": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "height": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        }
      }
    }
  }
}